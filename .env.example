# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here-change-this-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com
ALLAUTH_TRUSTED_PROXY_COUNT=1

# Database
DATABASE_URL=postgres://user:password@localhost:5432/tinashe_takeaway

# Payments
PAYMENT_PROVIDER=stripe

# Stripe Payments
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Payment fallback: when Stripe is unavailable, customers may place an unpaid held order.
PAYMENT_FALLBACK_ENABLED=True
PAYMENT_FALLBACK_HOLD_MINUTES=15

# Email — SMTP (transactional emails: order confirmations, password resets, admin alerts)
# Leave provider credentials blank to print emails to the shell/console.
# For local Mailpit previews, use:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=127.0.0.1
# EMAIL_PORT=1025
# EMAIL_USE_TLS=False
#
# For production with Google Workspace:
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=orders@yourdomain.com
# EMAIL_HOST_PASSWORD=<your-google-app-password>
EMAIL_BACKEND=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=orders@yourdomain.com
SERVER_EMAIL=orders@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_FAILURE_ALERTS_ENABLED=True
ADMIN_FAILURE_ALERT_THROTTLE_SECONDS=600

# Optional SendGrid API key (not used unless a SendGrid backend is added/configured)
SENDGRID_API_KEY=

# SMS
# console = fake local SMS, twilio_test = no-charge Twilio API test, twilio = real paid SMS.
SMS_BACKEND=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_TEST_ACCOUNT_SID=
TWILIO_TEST_AUTH_TOKEN=
TWILIO_TEST_PHONE_NUMBER=+15005550006

# Resend API (marketing emails — offers, campaigns, newsletters)
# https://resend.com — developer-first email API. Leave blank to log
# newsletter signups without sending external email.
RESEND_API_KEY=
RESEND_FROM_EMAIL=offers@yourdomain.com
RESEND_FROM_NAME=Tinashe Takeaway

# Web Push (order status notifications to installed PWAs).
# Generate once with: python manage.py generate_vapid_keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_ADMIN_EMAIL=orders@yourdomain.com

# Shop Settings
SHOP_NAME=Tinashe Takeaway
SHOP_ADDRESS=45 High Street, Your Town
SHOP_PHONE=+44 XXXX XXXXXX
SHOP_EMAIL=orders@tinashe.com
CURRENCY=GBP
TIME_ZONE=Europe/London

# Order Settings
ORDER_PREFIX=TN
DEFAULT_PREP_TIME=15
MAX_CART_ITEM_QUANTITY=20
# Deployment-level delivery kill switch. Admin Site Settings can only enable delivery when this is True.
DELIVERY_ENABLED=True
DELIVERY_MINIMUM_ORDER_AMOUNT=15.00
DELIVERY_DEFAULT_FEE=2.50
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_MAP_ID=
GOOGLE_MAPS_SERVER_API_KEY=
GOOGLE_ADDRESS_VALIDATION_ENABLED=False
GOOGLE_ADDRESS_VALIDATION_TIMEOUT_SECONDS=4
GOOGLE_ROUTES_API_ENABLED=False
GOOGLE_ROUTES_API_KEY=
GOOGLE_ROUTES_TIMEOUT_SECONDS=4
SHOP_LATITUDE=
SHOP_LONGITUDE=
DELIVERY_RADIUS_MILES=3

# Optional Pixabay key for reviewed food image imports.
# Run: python manage.py fetch_menu_images --dry-run --output /tmp/greenfish-pixabay.csv
PIXABAY_API_KEY=

# Async jobs / notification outbox
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# Security (Production)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
