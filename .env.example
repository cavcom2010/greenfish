# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here-change-this-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Database
DATABASE_URL=postgres://user:password@localhost:5432/tinashe_takeaway

# Payments
PAYMENT_PROVIDER=stripe

# Stripe Payments
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Payment fallback: when Stripe/Mollie is unavailable, customers may place an unpaid held order.
PAYMENT_FALLBACK_ENABLED=True
PAYMENT_FALLBACK_HOLD_MINUTES=15

# Mollie Payments (optional alternate provider)
MOLLIE_API_KEY=
MOLLIE_WEBHOOK_SECRET=

# Email
# Leave provider credentials blank to print emails to the shell/console.
EMAIL_BACKEND=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=orders@yourdomain.com

# Optional SendGrid API key (not used unless a SendGrid backend is added/configured)
SENDGRID_API_KEY=

# Sender.net API (marketing emails — offers, campaigns, newsletters)
# Leave blank to log newsletter signups without sending external email.
SENDER_NET_API_KEY=
SENDER_NET_FROM_EMAIL=offers@yourdomain.com
SENDER_NET_FROM_NAME=Tinashe Takeaway

# Shop Settings
SHOP_NAME=Tinashe Takeaway
SHOP_ADDRESS=45 High Street, Your Town
SHOP_PHONE=+44 XXXX XXXXXX
SHOP_EMAIL=orders@tinashe.com
CURRENCY=GBP
TIME_ZONE=Europe/London

# Order Settings
ORDER_PREFIX=TN
DEFAULT_PREP_TIME=15
MAX_CART_ITEM_QUANTITY=20
# Deployment-level delivery kill switch. Admin Site Settings can only enable delivery when this is True.
DELIVERY_ENABLED=True
DELIVERY_MINIMUM_ORDER_AMOUNT=15.00
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_MAP_ID=
GOOGLE_MAPS_SERVER_API_KEY=
GOOGLE_ADDRESS_VALIDATION_ENABLED=False
GOOGLE_ADDRESS_VALIDATION_TIMEOUT_SECONDS=4
GOOGLE_ROUTES_API_ENABLED=False
GOOGLE_ROUTES_API_KEY=
GOOGLE_ROUTES_TIMEOUT_SECONDS=4
SHOP_LATITUDE=
SHOP_LONGITUDE=
DELIVERY_RADIUS_MILES=3

# Async jobs / notification outbox
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# Security (Production)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
